[Unit]
Description=Run quay tick every minute

[Timer]
# Wall-clock cadence: every minute, on the minute (BRIX-1874). Anchored on the
# wall clock via OnCalendar rather than OnBootSec/OnUnitActiveSec, so the timer
# always has a next elapse and always re-arms after any stop/restart. A
# monotonic-only schedule (OnUnitActiveSec re-anchors off the *previous*
# service activation) can compute NO next trigger if the service is stopped and
# the timer is later started past boot with no prior activation to anchor on —
# it then sits active with `Trigger: n/a` and silently never fires again.
#
# Retune with an override drop-in
# (/etc/systemd/system/quay-tick.timer.d/override.conf via
# `sudo systemctl edit quay-tick.timer`), resetting OnCalendar first:
#   [Timer]
#   OnCalendar=
#   OnCalendar=*:0/2
OnCalendar=minutely
AccuracySec=15s
Persistent=true
Unit=quay-tick.service

[Install]
WantedBy=timers.target
