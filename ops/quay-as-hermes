#!/usr/bin/env bash
# quay-as-hermes — sanctioned operator path for ad-hoc quay invocations.
#
# Direct `sudo -u __AGENT_USER__ /usr/local/bin/quay …` strips
# QUAY_DATA_DIR, so quay's config-resolution order falls back to
# ~/.quay/config.toml — a parallel SQLite + repos dir under the agent's
# home that diverges silently from what the systemd tick writes to.
# This wrapper pins the data dir explicitly by default, so manual `repo add`,
# `task list`, `enqueue`, etc. land in the same place as the unit. Callers
# such as the gateway API server may still pass QUAY_DATA_DIR to target a
# profile-specific Quay store.
#
# `cd /` is required because sudo inherits the caller's cwd by default;
# from the canonical `ssh <host>; sudo …` flow that's /root (mode 0750,
# unreadable to the agent user). Quay stats its cwd at startup, fails
# silently when it can't, and falls back to ~/.quay/ — defeating the
# QUAY_DATA_DIR pin above. `/` is universally readable.
#
# We also load __TARGET_DIR__/auth/quay.env so adapter tokens
# (LINEAR_API_KEY, SLACK_TOKEN, …) reach ad-hoc invocations the same way
# they reach the systemd tick — without this, operator commands like
# `enqueue --linear-issue` fail despite the unit working fine.
#
# The load uses a strict KEY=VAL parser rather than shell `.` so
# semantics match systemd's EnvironmentFile= (which never expands shell
# metacharacters). A future env file containing `$(…)` in a value would
# execute as the agent user under `set -a; . file` but land as a
# literal under systemd; aligning the two parsers keeps that surface
# closed. Skips comment lines, blank lines, and any key outside
# [A-Z0-9_] (matches systemd's allowed key shape). The `[ -r … ]`
# guard keeps the wrapper usable on fresh installs that haven't run
# stage-secrets.sh yet.
#
# Finally, resolve the worker GitHub token from the GitHub App helper so any
# operator command that shells out to `gh` (enqueue's PR-existence pre-flight,
# review-pr, …) authenticates against the same identity as the systemd tick.
# Quay itself consumes $QUAY_WORKER_GH_TOKEN before spawning worker attempts,
# while child tools still read $GH_TOKEN / $GITHUB_TOKEN, so all three names
# are exported to the same token. Existing caller-supplied tokens are kept only
# when repo/PR-scoped GitHub probes accept them; stale, expired, or
# repo-unauthorized values mint a replacement.
# Mirrors
# ops/quay-tick-runner and ops/hermes-upstream-sync's preamble. Permissive
# on helper failure: missing PEM or transient mint error → exec and let
# quay's auth-error surface.
#
# Two invocation paths share this preamble:
#   1. operator path — root or fabian-on-host → drop to __AGENT_USER__ via sudo
#   2. agent path    — already __AGENT_USER__ (hermes-gateway shelling out
#                      from agent context) → skip sudo; the agent user is
#                      intentionally not in sudoers, so `sudo -u self` would
#                      reject and break agent-driven quay invocations.
# The cd /, quay.env load, and $GH_TOKEN mint apply identically in both,
# so the body is held in AGENT_BODY and re-entered via
# `sh -c "$AGENT_BODY" -- "$@"` either directly or under sudo. AGENT_BODY
# is single-quoted, so its "$@" stays literal until sh expands it against
# the script's forwarded argv.
#
# __AGENT_USER__ and __TARGET_DIR__ are substituted by setup-hermes.sh
# at install time, matching the quay-tick.service template pattern.

AGENT_BODY='
cd /
ENV_FILE=__TARGET_DIR__/auth/quay.env
if [ -r "$ENV_FILE" ]; then
  while IFS="=" read -r key value || [ -n "$key" ]; do
    case "$key" in
      ""|[0-9]*|*[!A-Z0-9_]*) continue ;;
    esac
    export "$key=$value"
  done < "$ENV_FILE"
fi
token_is_valid() {
  token="${QUAY_WORKER_GH_TOKEN:-${GH_TOKEN:-${GITHUB_TOKEN:-}}}"
  [ -n "$token" ] || return 1
  command -v gh >/dev/null 2>&1 || return 1
  repos=$(printf "%s" "${HERMES_QUAY_GITHUB_AUTH_REPOS:-${HERMES_QUAY_GITHUB_AUTH_REPO:-${GITHUB_REPOSITORY:-}}}" | tr "," " ")
  if [ -n "$repos" ]; then
    for repo in $repos; do
      token_has_repo_pr_access "$repo" || return 1
    done
    return 0
  fi
  found_repo=0
  if command -v git >/dev/null 2>&1; then
    repos_dir="${QUAY_DATA_DIR:-__TARGET_DIR__/quay}/repos"
    for bare in "$repos_dir"/*.git; do
      [ -d "$bare" ] || continue
      remote=$(git -C "$bare" config --get remote.origin.url 2>/dev/null || true)
      repo=""
      case "$remote" in
        https://github.com/*) repo="${remote#https://github.com/}" ;;
        http://github.com/*) repo="${remote#http://github.com/}" ;;
        git@github.com:*) repo="${remote#git@github.com:}" ;;
        ssh://git@github.com/*) repo="${remote#ssh://git@github.com/}" ;;
      esac
      repo="${repo%.git}"
      [ -n "$repo" ] || continue
      found_repo=1
      token_has_repo_pr_access "$repo" || return 1
    done
  fi
  [ "$found_repo" = 1 ] || return 1
}

token_has_repo_pr_access() {
  repo="${1#https://github.com/}"
  repo="${repo#http://github.com/}"
  repo="${repo%.git}"
  repo="${repo%/}"
  [ -n "$repo" ] || return 1
  GH_TOKEN="$token" \
    GITHUB_TOKEN="$token" \
    gh repo view "$repo" --json viewerPermission >/dev/null 2>&1 &&
  GH_TOKEN="$token" \
    GITHUB_TOKEN="$token" \
    gh pr list -R "$repo" --limit 1 >/dev/null 2>&1
}

export_worker_token() {
  export QUAY_WORKER_GH_TOKEN="$1"
  export GH_TOKEN="$1"
  export GITHUB_TOKEN="$1"
}

mint_gh_token() {
  PY=__TARGET_DIR__/hermes-agent/venv/bin/python
  HELPER=__TARGET_DIR__/hermes-agent/installer/hermes_github_token.py
  if [ ! -x "$PY" ] || [ ! -f "$HELPER" ]; then
    printf "[quay-as-hermes] WARN: token helper not found at %s; running quay without minted \$GH_TOKEN\n" "$HELPER" >&2
    return 1
  # `timeout 30` caps the worst-case mint at the shell layer, matching
  # quay-tick-runner. An operator command stays interactive even if the
  # App API hangs at the TCP/TLS layer.
  elif token=$(timeout 30 "$PY" "$HELPER" mint 2>/dev/null) && [ -n "$token" ]; then
    export_worker_token "$token"
  else
    printf "[quay-as-hermes] WARN: token mint failed; running quay without minted \$GH_TOKEN\n" >&2
    return 1
  fi
}

existing_token="${QUAY_WORKER_GH_TOKEN:-${GH_TOKEN:-${GITHUB_TOKEN:-}}}"
if [ -n "$existing_token" ]; then
  if ! token_is_valid; then
    printf "[quay-as-hermes] WARN: existing GitHub token is invalid; minting replacement\n" >&2
    unset QUAY_WORKER_GH_TOKEN GH_TOKEN GITHUB_TOKEN
    mint_gh_token || true
  else
    export_worker_token "$existing_token"
  fi
else
  mint_gh_token || true
fi
exec /usr/local/bin/quay "$@"
'

if [ "$(id -un)" = "__AGENT_USER__" ]; then
  export QUAY_DATA_DIR="${QUAY_DATA_DIR:-__TARGET_DIR__/quay}"
  export HERMES_HOME=__TARGET_DIR__
  exec sh -c "$AGENT_BODY" -- "$@"
else
  exec sudo -u __AGENT_USER__ \
       env "QUAY_DATA_DIR=${QUAY_DATA_DIR:-__TARGET_DIR__/quay}" HERMES_HOME=__TARGET_DIR__ \
       sh -c "$AGENT_BODY" -- "$@"
fi
