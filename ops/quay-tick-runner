#!/usr/bin/env bash
# quay-tick-runner — invoke `quay tick` with $GH_TOKEN minted from the
# installer's GitHub App helper.
#
# `gh pr list/create` and `git push` HTTPS both read $GH_TOKEN; minting
# once at the top of the tick covers every subprocess (claude worker,
# review-pr, dupe-check pre-flight). Mirrors ops/hermes-upstream-sync's
# preamble — same helper, same env-var contract.
#
# Permissive on helper failure: if the App PEM isn't staged or mint
# errors transiently, we exec `quay tick` without $GH_TOKEN. Quay's
# existing auth-error message surfaces downstream, rather than blocking
# the timer on a transient mint failure.
#
# Environment overrides (mostly for tests / non-default installs):
#   HERMES_HOME          — install root (default: $HOME/.hermes)
#   HERMES_TOKEN_HELPER  — token helper path (default: render under
#                          $HERMES_HOME/hermes-agent/installer/hermes_github_token.py)
#   HERMES_TOKEN_PYTHON  — venv python (default: render under
#                          $HERMES_HOME/hermes-agent/venv/bin/python)
#   GH_TOKEN             — when set, used as-is and the helper is skipped

set -u

LOG_PREFIX="quay-tick-runner"
warn() { printf '[%s] WARN: %s\n' "$LOG_PREFIX" "$*" >&2; }

if [[ -z "${GH_TOKEN:-${GITHUB_TOKEN:-}}" ]]; then
  HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
  HERMES_TOKEN_HELPER="${HERMES_TOKEN_HELPER:-$HERMES_HOME/hermes-agent/installer/hermes_github_token.py}"
  HERMES_TOKEN_PYTHON="${HERMES_TOKEN_PYTHON:-$HERMES_HOME/hermes-agent/venv/bin/python}"
  if [[ -x "$HERMES_TOKEN_PYTHON" && -f "$HERMES_TOKEN_HELPER" ]]; then
    if token="$(HERMES_HOME="$HERMES_HOME" "$HERMES_TOKEN_PYTHON" "$HERMES_TOKEN_HELPER" mint 2>/dev/null)" \
         && [[ -n "$token" ]]; then
      export GH_TOKEN="$token"
    else
      warn "token mint failed; running tick without \$GH_TOKEN"
    fi
  else
    warn "token helper not found at $HERMES_TOKEN_HELPER; running tick without \$GH_TOKEN"
  fi
fi

exec /usr/local/bin/quay tick "$@"
