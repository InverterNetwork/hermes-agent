#!/usr/bin/env bash
# quay-tick-runner — invoke `quay tick` with GitHub App installation
# tokens minted from the installer's shared helper.
#
# Quay consumes $QUAY_WORKER_GH_TOKEN before spawning worker attempts.
# Worker subprocesses (`gh pr list/create`, `git push` HTTPS, etc.) still read
# $GH_TOKEN / $GITHUB_TOKEN, so minting once at the top of the tick exports all
# three names to the same worker App token. Reviewer attempts must post as a
# separate GitHub App, so this runner also mints $QUAY_REVIEWER_GH_TOKEN from
# /etc/hermes/reviewer.env before `quay tick`.
# Mirrors ops/hermes-upstream-sync's preamble — same helper, same env-var
# contract — with a role-specific reviewer config path layered on top.
#
# Strict on worker helper failure: stale inherited tokens are replaced and
# missing/unmintable tokens fail before `quay tick`, so waiting_human recovery
# and spawned workers never run with stale GH_TOKEN/GITHUB_TOKEN.
#
# Environment overrides (mostly for tests / non-default installs):
#   HERMES_HOME          — install root (default: $HOME/.hermes)
#   HERMES_TOKEN_HELPER  — token helper path (default: render under
#                          $HERMES_HOME/hermes-agent/installer/hermes_github_token.py)
#   HERMES_TOKEN_PYTHON  — venv python (default: render under
#                          $HERMES_HOME/hermes-agent/venv/bin/python)
#   QUAY_WORKER_GH_TOKEN / GH_TOKEN / GITHUB_TOKEN
#                        — when any is set, kept only if repo/PR-scoped
#                          GitHub probes accept it. Invalid, expired, or
#                          repo-unauthorized values are replaced by a freshly
#                          minted helper token exported under all three names.
#   HERMES_QUAY_GITHUB_AUTH_REPO(S)
#                        — optional owner/repo probe target(s). When unset,
#                          the auth helper probes registered Quay bare clone
#                          origins from $QUAY_DATA_DIR/repos.
#   HERMES_REVIEWER_GH_CONFIG
#                        — reviewer App env file (default:
#                          /etc/hermes/reviewer.env)
#   QUAY_REVIEWER_GH_TOKEN
#                        — when set, used as-is and the reviewer helper is
#                          skipped
#   QUAY_BIN             — quay binary path (default: /usr/local/bin/quay)

set -u

LOG_PREFIX="quay-tick-runner"
warn() { printf '[%s] WARN: %s\n' "$LOG_PREFIX" "$*" >&2; }

AUTH_HELPER="${HERMES_QUAY_GITHUB_AUTH:-${HERMES_HOME:-$HOME/.hermes}/hermes-agent/ops/quay-github-auth}"
if [[ ! -f "$AUTH_HELPER" ]]; then
  AUTH_HELPER="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/quay-github-auth"
fi
if [[ ! -f "$AUTH_HELPER" ]]; then
  printf '[%s] ERROR: GitHub auth helper not found; checked HERMES_QUAY_GITHUB_AUTH and %s\n' "$LOG_PREFIX" "$AUTH_HELPER" >&2
  exit 64
fi
quay_auth_log_prefix="$LOG_PREFIX"
# shellcheck source=ops/quay-github-auth
source "$AUTH_HELPER"

mint_from_helper() {
  local label="$1"
  local config="${2:-}"
  local home="${HERMES_HOME:-$HOME/.hermes}"
  local helper="${HERMES_TOKEN_HELPER:-$home/hermes-agent/installer/hermes_github_token.py}"
  local py="${HERMES_TOKEN_PYTHON:-$home/hermes-agent/venv/bin/python}"

  if [[ ! -x "$py" || ! -f "$helper" ]]; then
    warn "$label token helper not found at $helper; running tick without $label token"
    return 1
  fi

  # `timeout 30` makes the worst-case mint latency legible at the bash
  # layer — a future bump to the helper's internal HTTP_TIMEOUT_S
  # shouldn't silently extend our tick startup. 30s is well under the
  # unit's TimeoutStartSec=600 but tight enough that a wedged DNS / TLS
  # handshake doesn't waste a full tick.
  local token
  local -a env_args=(env)
  if [[ -n "$config" ]]; then
    # The reviewer App identity must come from its own config file. Strip
    # generic helper overrides so a worker App env var cannot silently
    # replace the reviewer App credentials.
    env_args+=(
      -u HERMES_GH_CONFIG
      -u HERMES_GH_APP_ID
      -u HERMES_GH_INSTALLATION_ID
      -u HERMES_GH_APP_KEY
      -u HERMES_GH_API
      -u HERMES_GH_TOKEN_CACHE
      -u HERMES_GH_TOKEN_OVERRIDE
      HERMES_GH_CONFIG="$config"
    )
  fi
  env_args+=(HERMES_HOME="$home")
  if ! token="$(timeout 30 "${env_args[@]}" "$py" "$helper" mint 2>/dev/null)" \
       || [[ -z "$token" ]]; then
    warn "$label token mint failed; running tick without $label token"
    return 1
  fi
  printf '%s\n' "$token"
}

mint_reviewer_gh_token() {
  [[ -n "${QUAY_REVIEWER_GH_TOKEN:-}" ]] && return 0

  local config="${HERMES_REVIEWER_GH_CONFIG:-/etc/hermes/reviewer.env}"
  [[ -f "$config" ]] || return 0

  local token
  token="$(mint_from_helper "reviewer" "$config")" || return 0
  export QUAY_REVIEWER_GH_TOKEN="$token"
}

quay_prepare_worker_github_auth
mint_reviewer_gh_token
exec "${QUAY_BIN:-/usr/local/bin/quay}" tick "$@"
