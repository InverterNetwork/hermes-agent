[Unit]
Description=Run hermes-upstream-sync weekly

[Timer]
# Weekly cadence — code is lower-frequency than state. Mondays at 09:00 UTC
# so any conflicts surface during the work week. Override via
# `systemctl edit hermes-upstream-sync.timer`:
#   [Timer]
#   OnCalendar=
#   OnCalendar=Sun *-*-* 03:00:00 UTC
OnCalendar=Mon *-*-* 09:00:00 UTC
RandomizedDelaySec=15min
Persistent=true
Unit=hermes-upstream-sync.service

[Install]
WantedBy=timers.target
