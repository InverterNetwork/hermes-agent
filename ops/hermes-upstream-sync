#!/usr/bin/env bash
# hermes-upstream-sync — propose an upstream merge as a PR.
#
# Detects when upstream/main is ahead of the merge-base with origin/main and
# opens a PR for human review from an isolated temporary worktree. Conflicts
# produce a draft PR flagged in the title — never attempts auto-resolution.
# Branch protection on origin/main enforces that the agent (with non-admin
# write access) cannot merge.
#
# Run manually or from a low-frequency timer (weekly is the intended
# default — code, not state).
#
# Required:
#   gh, git, an `upstream` remote, an `origin` remote, push permission to
#   origin, and `gh` auth. The script resolves a GitHub App installation
#   token at the top of every tick — minting via the installer's helper
#   when neither $GH_TOKEN nor $GITHUB_TOKEN is set, or honoring the
#   caller-supplied value as-is — and exports it as $GH_TOKEN for `gh`.
#   For `git push` over HTTPS the script wires an inline
#   credential.https://github.com.helper that emits the same $GH_TOKEN
#   as the password, because git does not consult $GH_TOKEN on its
#   own; without the helper the unattended timer dies on git's
#   username prompt.
#
# Environment overrides:
#   FORK_DIR             — fork working copy (default: cwd or
#                          /srv/hermes/repos/hermes-agent)
#   UPSTREAM_REMOTE      — remote name (default: upstream)
#   ORIGIN_REMOTE        — remote name (default: origin)
#   BASE_BRANCH          — origin branch the PR targets (default: main)
#   UPSTREAM_BRANCH      — upstream branch to merge (default: main)
#   PR_DRY_RUN           — when set, prints what would happen and exits 0
#   GITHUB_REPOSITORY    — owner/repo for the GitHub REST API PR endpoint
#                          (default: derived from the origin remote URL)
#   HERMES_HOME          — install root (default: $HOME/.hermes)
#   HERMES_TOKEN_HELPER  — token helper path (default: render under
#                          $HERMES_HOME/hermes-agent/installer/hermes_github_token.py)
#   HERMES_TOKEN_PYTHON  — venv python for the helper (default: render
#                          under $HERMES_HOME/hermes-agent/venv/bin/python)
#   HERMES_UPSTREAM_SYNC_STATE_DIR
#                        — status/lock directory (default:
#                          $HERMES_HOME/state/hermes-upstream-sync)
#   HERMES_UPSTREAM_SYNC_WORKTREE_ROOT
#                        — temp-worktree parent (default: ${TMPDIR:-/tmp})
#   GH_TOKEN             — when set, used as-is and the helper is skipped

set -uo pipefail

UPSTREAM_REMOTE="${UPSTREAM_REMOTE:-upstream}"
ORIGIN_REMOTE="${ORIGIN_REMOTE:-origin}"
BASE_BRANCH="${BASE_BRANCH:-main}"
UPSTREAM_BRANCH="${UPSTREAM_BRANCH:-main}"
LOG_PREFIX="hermes-upstream-sync"

log()  { printf '[%s] %s\n' "$LOG_PREFIX" "$*"; }
warn() { printf '[%s] WARN: %s\n' "$LOG_PREFIX" "$*" >&2; }

record_status() {
  [[ -n "${STATUS_FILE:-}" ]] || return 0
  local state="$1"
  local detail="${2:-}"
  mkdir -p "$STATE_DIR" 2>/dev/null || return 0
  {
    printf 'timestamp=%q\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf 'state=%q\n' "$state"
    printf 'detail=%q\n' "$detail"
    printf 'fork_dir=%q\n' "${FORK_DIR:-}"
    printf 'branch=%q\n' "${BRANCH:-}"
    printf 'upstream_ref=%q\n' "${UPSTREAM_REF:-}"
    printf 'upstream_sha=%q\n' "${UPSTREAM_SHA:-}"
    printf 'origin_ref=%q\n' "${ORIGIN_REF:-}"
  } > "${STATUS_FILE}.tmp" 2>/dev/null && mv "${STATUS_FILE}.tmp" "$STATUS_FILE" 2>/dev/null || true
}

die()  {
  printf '[%s] FAIL: %s\n' "$LOG_PREFIX" "$*" >&2
  record_status failed "$*"
  exit 1
}

github_repo_full_name() {
  local remote_url="$1"
  local repo=""

  case "$remote_url" in
    https://github.com/*)
      repo="${remote_url#https://github.com/}"
      ;;
    http://github.com/*)
      repo="${remote_url#http://github.com/}"
      ;;
    https://*@github.com/*)
      repo="${remote_url#https://*@github.com/}"
      ;;
    http://*@github.com/*)
      repo="${remote_url#http://*@github.com/}"
      ;;
    git@github.com:*)
      repo="${remote_url#git@github.com:}"
      ;;
    ssh://git@github.com/*)
      repo="${remote_url#ssh://git@github.com/}"
      ;;
    *)
      return 1
      ;;
  esac

  repo="${repo%/}"
  repo="${repo%.git}"
  [[ "$repo" =~ ^[^/]+/[^/]+$ ]] || return 1
  printf '%s\n' "$repo"
}

# Resolve the fork working copy. Fall back to a few well-known paths so the
# script can run from a timer without an explicit cwd.
if [[ -z "${FORK_DIR:-}" ]]; then
  if git rev-parse --show-toplevel >/dev/null 2>&1; then
    FORK_DIR="$(git rev-parse --show-toplevel)"
  elif [[ -d /srv/hermes/repos/hermes-agent/.git ]]; then
    FORK_DIR="/srv/hermes/repos/hermes-agent"
  else
    die "no FORK_DIR set and not inside a git repo"
  fi
fi
[[ -d "$FORK_DIR/.git" ]] \
  || die "FORK_DIR is not a git repo: $FORK_DIR"

cd "$FORK_DIR"

command -v gh >/dev/null 2>&1 \
  || die "gh CLI not on PATH"

# Resolve the helper paths once. Used both for minting $GH_TOKEN (for
# `gh`) and for wiring a per-push git credential helper below. Default
# locations match the installer layout; env overrides exist for tests
# and non-default --target installs.
HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
HERMES_TOKEN_HELPER="${HERMES_TOKEN_HELPER:-$HERMES_HOME/hermes-agent/installer/hermes_github_token.py}"
HERMES_TOKEN_PYTHON="${HERMES_TOKEN_PYTHON:-$HERMES_HOME/hermes-agent/venv/bin/python}"
STATE_DIR="${HERMES_UPSTREAM_SYNC_STATE_DIR:-$HERMES_HOME/state/hermes-upstream-sync}"
STATUS_FILE="$STATE_DIR/status.env"
LOCK_DIR="${HERMES_UPSTREAM_SYNC_LOCK_DIR:-$STATE_DIR/lock}"
WORKTREE_DIR=""
LOCK_ACQUIRED=0

cleanup() {
  local rc=$?
  if [[ -n "$WORKTREE_DIR" && -d "$WORKTREE_DIR" ]]; then
    git -C "$FORK_DIR" worktree remove --force "$WORKTREE_DIR" >/dev/null 2>&1 \
      || rm -rf "$WORKTREE_DIR" >/dev/null 2>&1 || true
  fi
  if [[ "$LOCK_ACQUIRED" -eq 1 ]]; then
    rm -rf "$LOCK_DIR" >/dev/null 2>&1 || true
  fi
  return "$rc"
}

acquire_lock() {
  mkdir -p "$STATE_DIR" 2>/dev/null || die "cannot create state dir: $STATE_DIR"
  if mkdir "$LOCK_DIR" 2>/dev/null; then
    LOCK_ACQUIRED=1
    printf '%s\n' "$$" > "$LOCK_DIR/pid" 2>/dev/null || true
    return 0
  fi

  local old_pid=""
  old_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
  if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
    warn "another hermes-upstream-sync run is active (pid $old_pid); skipping"
    record_status skipped "another run active pid=$old_pid"
    exit 0
  fi

  warn "removing stale lock at $LOCK_DIR"
  rm -rf "$LOCK_DIR" 2>/dev/null || die "stale lock exists and cannot be removed: $LOCK_DIR"
  mkdir "$LOCK_DIR" 2>/dev/null || die "cannot acquire lock: $LOCK_DIR"
  LOCK_ACQUIRED=1
  printf '%s\n' "$$" > "$LOCK_DIR/pid" 2>/dev/null || true
}

trap cleanup EXIT
acquire_lock
record_status running "starting upstream sync"

HELPER_AVAILABLE=0
if [[ -x "$HERMES_TOKEN_PYTHON" && -f "$HERMES_TOKEN_HELPER" ]]; then
  HELPER_AVAILABLE=1
fi

# Mint a GitHub App installation token for `gh` unless the caller supplied
# one. `gh` reads $GH_TOKEN/$GITHUB_TOKEN; `git push` does NOT — the push
# is auth'd separately via the credential helper wired into the push
# command below.
if [[ -z "${GH_TOKEN:-${GITHUB_TOKEN:-}}" ]]; then
  if [[ "$HELPER_AVAILABLE" -eq 1 ]]; then
    log "minting GitHub App installation token via $HERMES_TOKEN_HELPER"
    GH_TOKEN="$(HERMES_HOME="$HERMES_HOME" "$HERMES_TOKEN_PYTHON" "$HERMES_TOKEN_HELPER" mint)" \
      || die "token helper failed; check $HERMES_HOME/auth/github-app.env"
    export GH_TOKEN
  else
    warn "no GH_TOKEN in env and token helper not found at $HERMES_TOKEN_HELPER"
    warn "gh/git auth will fall back to whatever's in ~/.config/gh or git's credential helper"
  fi
fi

# Per-push git credential helper. Emits whatever $GH_TOKEN ended up in
# scope above — caller-supplied via EnvironmentFile or freshly minted
# from $HERMES_TOKEN_HELPER — so a single resolved token covers both
# GitHub REST API calls and the preceding `git push`.
#
# The helper body is single-quoted so $GH_TOKEN stays literal in the
# config; git invokes it via `sh -c`, and that sh expands it from our
# exported env. The token value never appears in `ps` output (only the
# literal "$GH_TOKEN" reference does). Scoped to https://github.com so
# the helper can't fire for an unexpected remote — defense in depth;
# origin should always be on github.com.
GIT_CRED_HELPER=""
if [[ -n "${GH_TOKEN:-${GITHUB_TOKEN:-}}" ]]; then
  GIT_CRED_HELPER='!f() { printf "username=x-access-token\npassword=%s\n" "${GH_TOKEN:-$GITHUB_TOKEN}"; }; f'
fi

# Sanity-check remotes.
git remote get-url "$UPSTREAM_REMOTE" >/dev/null 2>&1 \
  || die "no '$UPSTREAM_REMOTE' remote configured in $FORK_DIR"
git remote get-url "$ORIGIN_REMOTE" >/dev/null 2>&1 \
  || die "no '$ORIGIN_REMOTE' remote configured in $FORK_DIR"

# A dirty primary checkout no longer blocks the timer. All merge work happens
# in an isolated temporary worktree below; this warning is only operational
# context for the journal/status file.
if [[ -n "$(git status --porcelain)" ]]; then
  warn "primary checkout is dirty; continuing in an isolated sync worktree"
fi

log "fetching $UPSTREAM_REMOTE/$UPSTREAM_BRANCH and $ORIGIN_REMOTE/$BASE_BRANCH"
git fetch --quiet "$UPSTREAM_REMOTE" "$UPSTREAM_BRANCH" \
  || die "fetch $UPSTREAM_REMOTE failed"
git fetch --quiet "$ORIGIN_REMOTE" "$BASE_BRANCH" \
  || die "fetch $ORIGIN_REMOTE failed"

UPSTREAM_REF="$UPSTREAM_REMOTE/$UPSTREAM_BRANCH"
ORIGIN_REF="$ORIGIN_REMOTE/$BASE_BRANCH"
UPSTREAM_SHA="$(git rev-parse "$UPSTREAM_REF")"
MERGE_BASE="$(git merge-base "$UPSTREAM_REF" "$ORIGIN_REF")"

# No new upstream commits → nothing to do.
if [[ "$UPSTREAM_SHA" == "$MERGE_BASE" ]]; then
  log "$UPSTREAM_REF is fully merged into $ORIGIN_REF; nothing to do"
  record_status ok "$UPSTREAM_REF already merged into $ORIGIN_REF"
  exit 0
fi

UPSTREAM_SHORT="$(git rev-parse --short "$UPSTREAM_REF")"
DATE_TAG="$(date -u +%Y-%m-%d)"
BRANCH="upstream-sync/${DATE_TAG}-${UPSTREAM_SHORT}"

# Refuse to clobber an in-flight sync branch with the same name. Either the
# previous one was merged (and the next tick is a no-op above) or it's still
# open and the operator needs to deal with it before we propose another.
if git ls-remote --exit-code --heads "$ORIGIN_REMOTE" "$BRANCH" >/dev/null 2>&1; then
  warn "$BRANCH already exists on $ORIGIN_REMOTE; skipping"
  record_status skipped "$BRANCH already exists on $ORIGIN_REMOTE"
  exit 0
fi

if [[ -n "${PR_DRY_RUN:-}" ]]; then
  log "DRY RUN: would propose merge of $UPSTREAM_REF (@$UPSTREAM_SHORT) onto $ORIGIN_REF as $BRANCH"
  record_status dry-run "would propose $BRANCH"
  exit 0
fi

if [[ -z "${GITHUB_REPOSITORY:-}" ]]; then
  ORIGIN_URL="$(git remote get-url "$ORIGIN_REMOTE")"
  GITHUB_REPOSITORY="$(github_repo_full_name "$ORIGIN_URL")" \
    || die "could not derive GitHub owner/repo from '$ORIGIN_REMOTE' remote; set GITHUB_REPOSITORY=owner/repo"
fi
GITHUB_REPOSITORY="${GITHUB_REPOSITORY%/}"
GITHUB_REPOSITORY="${GITHUB_REPOSITORY%.git}"
[[ "$GITHUB_REPOSITORY" =~ ^[^/]+/[^/]+$ ]] \
  || die "GITHUB_REPOSITORY must be owner/repo, got: $GITHUB_REPOSITORY"

# A previous tick that pushed-and-died (or was killed mid-merge) can leave
# a local branch with the same name. The remote check above already
# returned "no such branch on origin", so the local one is stale —
# delete it so `worktree add -b` can recreate cleanly. -D over -d because the
# stale branch may have unmerged commits from a half-completed previous run.
if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
  warn "stale local $BRANCH from a previous failed tick; deleting"
  git branch -D "$BRANCH" >/dev/null
fi

WORKTREE_ROOT="${HERMES_UPSTREAM_SYNC_WORKTREE_ROOT:-${TMPDIR:-/tmp}}"
mkdir -p "$WORKTREE_ROOT" 2>/dev/null || die "cannot create worktree root: $WORKTREE_ROOT"
WORKTREE_DIR="$WORKTREE_ROOT/hermes-upstream-sync-${DATE_TAG}-${UPSTREAM_SHORT}-$$"

log "creating isolated worktree $WORKTREE_DIR for $BRANCH off $ORIGIN_REF"
git worktree add -q -b "$BRANCH" "$WORKTREE_DIR" "$ORIGIN_REF" \
  || die "failed to create sync worktree for $BRANCH"
cd "$WORKTREE_DIR"
record_status running "created sync worktree for $BRANCH"

PR_TITLE="Sync upstream hermes-agent @ $UPSTREAM_SHORT"
# Tilde fences (CommonMark-valid) instead of triple-backtick so commit
# subjects or filenames containing literal backticks can't break the
# code-block boundary in the PR body.
PR_BODY="Brings in upstream commits up to \`$UPSTREAM_SHORT\` (\`$UPSTREAM_REF\`).

Generated by \`ops/hermes-upstream-sync\`. Branch protection on \`$BASE_BRANCH\`
enforces that the agent cannot self-merge — review and merge manually.

~~~
$(git log --oneline "$MERGE_BASE..$UPSTREAM_SHA" | head -50)
~~~"

PR_DRAFT=0

if git merge --no-edit --no-ff "$UPSTREAM_REF"; then
  log "clean merge; pushing $BRANCH"
else
  warn "merge conflicts detected; staging conflict markers and opening a draft PR"
  # Capture the conflict file list while git still tracks them as unmerged
  # (--diff-filter=U); after the WIP commit they're plain modifications.
  CONFLICT_FILES="$(git diff --name-only --diff-filter=U)"
  git add -A
  git commit -q -m "WIP: upstream sync with conflicts (resolve before merging)"
  PR_TITLE="$PR_TITLE (CONFLICTS)"
  PR_BODY="**Conflicts detected.** Resolve manually before marking ready.

Files with conflict markers:
~~~
$CONFLICT_FILES
~~~

$PR_BODY"
  PR_DRAFT=1
  record_status conflicts "opened draft PR branch $BRANCH with conflicts"
fi

# Reset any inherited credential.helper chain on github.com (the empty
# first `-c` clears it) before layering ours on, so an operator's global
# helper (e.g. osxkeychain on a dev box) can't shadow the App token.
# When the helper isn't available, push without the override and let
# whatever git is already configured with carry the request.
if [[ -n "$GIT_CRED_HELPER" ]]; then
  git \
    -c "credential.https://github.com.helper=" \
    -c "credential.https://github.com.helper=$GIT_CRED_HELPER" \
    push --quiet -u "$ORIGIN_REMOTE" "$BRANCH" \
    || die "push $BRANCH failed; resolve and retry"
else
  git push --quiet -u "$ORIGIN_REMOTE" "$BRANCH" \
    || die "push $BRANCH failed; resolve and retry"
fi

log "opening PR: $PR_TITLE"
PR_API_FIELDS=(
  -f "title=$PR_TITLE"
  -f "head=$BRANCH"
  -f "base=$BASE_BRANCH"
  -f "body=$PR_BODY"
)
if [[ "$PR_DRAFT" -eq 1 ]]; then
  PR_API_FIELDS+=(-F "draft=true")
fi

PR_URL="$(gh api "repos/$GITHUB_REPOSITORY/pulls" -X POST "${PR_API_FIELDS[@]}" --jq .html_url)" \
  || die "gh api create pull request failed"

if [[ -n "$PR_URL" ]]; then
  log "done — PR opened against $ORIGIN_REMOTE/$BASE_BRANCH: $PR_URL"
else
  log "done — PR opened against $ORIGIN_REMOTE/$BASE_BRANCH"
fi
record_status ok "PR opened for $BRANCH against $ORIGIN_REMOTE/$BASE_BRANCH"
