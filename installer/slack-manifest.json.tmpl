{
    "display_information": {
        "name": "${slack.app.display_name}",
        "description": "${slack.app.description}",
        "background_color": "${slack.app.background_color}"
    },
    "features": {
        "bot_user": {
            "display_name": "${slack.app.display_name}",
            "always_online": false
        },
        "slash_commands": [
            {
                "command": "/${slack.app.slash_command_name}",
                "description": "${slack.app.slash_command_description}",
                "usage_hint": "[questions]",
                "should_escape": false
            }
        ]
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "app_mentions:read",
                "channels:history",
                "channels:read",
                "chat:write",
                "commands",
                "files:read",
                "files:write",
                "groups:history",
                "groups:read",
                "im:history",
                "im:read",
                "im:write",
                "reactions:write",
                "users:read"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "app_mention",
                "message.channels",
                "message.groups",
                "message.im"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false,
        "is_mcp_enabled": false
    }
}
